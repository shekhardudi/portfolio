# intelli-search backend env vars
ENVIRONMENT=production
LOG_LEVEL=INFO

# OpenSearch (docker-network service name in prod compose)
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=ChangeMe-SetViaSSM
OPENSEARCH_INDEX_NAME=linkedin_profiles

# Redis (docker-network service name)
REDIS_URL=redis://redis:6379/0

# LLM keys
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=

# Feature flags
ENABLE_QUERY_CLASSIFICATION=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_AGENTIC_SEARCH=true

# Observability (optional — leave blank to disable)
OTLP_ENDPOINT=
OTEL_SERVICE_NAME=intelli-search
