# =====================================================================
# Required keys
# =====================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Optional
SERPER_API_KEY=

# =====================================================================
# Models — every LLM call routes through one of these strings.
# Crew/LiteLLM identifiers use "<provider>/<model-id>" form.
# Visual Director uses Anthropic SDK directly; we strip the prefix.
# Image model is OpenAI's gpt-image-1.
# =====================================================================
CREW_RESEARCHER_MODEL=openai/gpt-5
CREW_WRITER_MODEL=anthropic/claude-opus-4-7
CREW_CRITIC_MODEL=anthropic/claude-sonnet-4-6
VISUAL_DIRECTOR_MODEL=anthropic/claude-sonnet-4-6
IMAGE_MODEL=gpt-image-1

# Visual Director tunables
VISUAL_DIRECTOR_TEMPERATURE=0.7
VISUAL_DIRECTOR_MAX_TOKENS=900

# Image generation defaults
IMAGE_DEFAULT_SIZE=1024x1024
IMAGE_DEFAULT_QUALITY=medium

# =====================================================================
# Pulse Scout
# =====================================================================
SCOUT_USE_OPENAI=true
SCOUT_OPENAI_MODEL=gpt-4o-mini
SCOUT_SYNTHESIS_TEMPERATURE=0.7

# Local Ollama (only used when SCOUT_USE_OPENAI=false)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_NUM_CTX=8192

# =====================================================================
# API config
# =====================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*
LOG_PRETTY=true
LOG_LEVEL=INFO

# Rate limits — slowapi notation, e.g. "5/minute" or "100/hour"
RATE_LIMIT_POSTS=5/minute
RATE_LIMIT_IMAGES=10/minute

# Job runner
MAX_CONCURRENT_POST_JOBS=2
